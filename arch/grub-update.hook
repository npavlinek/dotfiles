[Trigger]
Operation = Upgrade

Type = Package
Target = grub

[Action]
Description = Regenerate grub if updated
When = PostTransaction
Depends = grub
Exec = /bin/sh -c "/usr/bin/grub-install --target=x86_64-efi --efi-directory=/boot --bootloader-id=ARCH && /usr/bin/grub-mkconfig -o /boot/grub/grub.cfg"
